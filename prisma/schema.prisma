generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum BookingType {
  MEAL_PREP
  CATERING
  CHEF_EVENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  FAILED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  phone        String?
  address      String?
  role         UserRole  @default(CUSTOMER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]
}

model MealPlan {
  id                  String    @id @default(cuid())
  name                String
  description         String
  mealsPerWeek        Int
  calories            Int?
  dietaryTags         String[]
  price               Decimal   @db.Decimal(10, 2)
  isSubscription      Boolean   @default(true)
  deliveryDays        String[]
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  bookings            Booking[]
}

model CateringMenu {
  id                 String    @id @default(cuid())
  category           String
  title              String
  description        String
  pricePerPerson     Decimal   @db.Decimal(10, 2)
  minimumGuestCount  Int
  serviceHours       Int       @default(3)
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  bookings           Booking[]
}

model ChefService {
  id              String    @id @default(cuid())
  eventType       String
  title           String
  description     String
  pricingModel    String
  basePrice       Decimal   @db.Decimal(10, 2)
  hourlyRate      Decimal?  @db.Decimal(10, 2)
  minimumGuests   Int
  durationHours   Int
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  bookings        Booking[]
}

model Booking {
  id                String         @id @default(cuid())
  type              BookingType
  status            BookingStatus  @default(PENDING)
  totalPrice        Decimal        @db.Decimal(10, 2)
  depositAmount     Decimal        @db.Decimal(10, 2)
  guestCount        Int?
  startAt           DateTime
  endAt             DateTime
  timezone          String
  eventAddress      String?
  specialRequests   String?
  serviceAgreement  Boolean        @default(false)
  deliveryFrequency String?
  isRecurring       Boolean        @default(false)
  userId            String
  mealPlanId        String?
  cateringMenuId    String?
  chefServiceId     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlan          MealPlan?      @relation(fields: [mealPlanId], references: [id], onDelete: SetNull)
  cateringMenu      CateringMenu?  @relation(fields: [cateringMenuId], references: [id], onDelete: SetNull)
  chefService       ChefService?   @relation(fields: [chefServiceId], references: [id], onDelete: SetNull)
  payments          Payment[]
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String
  stripePaymentIntentId String?
  stripeSessionId       String?
  amount                Decimal       @db.Decimal(10, 2)
  status                PaymentStatus @default(PENDING)
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  booking               Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Availability {
  id          String   @id @default(cuid())
  date        DateTime
  startHour   Int
  endHour     Int
  isAvailable Boolean  @default(true)
  timezone    String   @default("America/Los_Angeles")
  bufferHours Int      @default(2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, startHour, endHour])
}
